{
  "name": "hivework-indexer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema ../api/prisma/schema.prisma --output ./src/generated/prisma",
    "codama:generate": "tsx scripts/codama.ts"
  },
  "dependencies": {
    "@solana/kit": "6.9.0",
    "@prisma/client": "7.8.0",
    "ws": "^8.18.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "tsx": "^4.19.2",
    "prisma": "7.8.0",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13"
  },
  "engines": {
    "node": ">=22"
  }
}