{
  "name": "hivework-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "test": "node --import tsx --test 'src/tests/**/*.test.ts'"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@solana/kit": "^6.9.0",
    "dotenv": "^16.0.0",
    "fastify": "5.8.5",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^5.0.0",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "prisma": "7.8.0",
    "tsx": "^4.20.0",
    "typescript": "latest"
  }
}
