generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CampaignStatus {
  draft
  active
  closed
}

enum NodeLevel {
  L1
  L2
  L3
}

enum DraftStatus {
  draft
  finalized
}

enum ConversionStatus {
  pending
  verified
  pushed_to_chain
  rejected
}

enum Platform {
  tiktok
  instagram
  x
  youtube
  other
}

model CampaignMetadata {
  id                  String         @id @default(cuid())
  onchainPda          String?        @unique @map("onchain_pda")
  status              CampaignStatus @default(draft)
  brandName           String         @map("brand_name")
  brandLogoUrl        String?        @map("brand_logo_url")
  productName         String         @map("product_name")
  productImageUrl     String?        @map("product_image_url")
  productDescription  String         @map("product_description") @db.Text
  redirectUrl         String         @map("redirect_url")
  creatorWallet       String         @map("creator_wallet")
  poolUsdc            Decimal        @default(0) @map("pool_usdc") @db.Decimal(18, 6)
  deadline            DateTime?
  createdAt           DateTime       @default(now()) @map("created_at")

  nodes               NodeMetadata[]
  leaves              LeafMetadata[]
  payoutClaims        PayoutClaim[]

  @@index([status])
  @@map("campaigns_metadata")
}

model NodeMetadata {
  id                String           @id @default(cuid())
  onchainPda        String?          @unique @map("onchain_pda")
  campaignId        String           @map("campaign_id")
  level             NodeLevel
  parentNodeId      String?          @map("parent_node_id")
  creatorWallet     String           @map("creator_wallet")
  title             String
  description       String           @db.Text
  examples          Json?
  tags              String[]
  mediaUrls         String[]         @map("media_urls")
  stakeSol          Decimal          @default(0) @map("stake_sol") @db.Decimal(18, 9)
  forkCount         Int              @default(0) @map("fork_count")
  conversionsCount  Int              @default(0) @map("conversions_count")
  status            DraftStatus      @default(draft)
  createdAt         DateTime         @default(now()) @map("created_at")

  campaign          CampaignMetadata @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parent            NodeMetadata?    @relation("NodeChildren", fields: [parentNodeId], references: [id])
  children          NodeMetadata[]   @relation("NodeChildren")

  @@index([campaignId, level])
  @@index([parentNodeId])
  @@map("nodes_metadata")
}

model LeafMetadata {
  id              String              @id @default(cuid())
  onchainPda      String?             @unique @map("onchain_pda")
  campaignId      String              @map("campaign_id")
  path            String[]
  creatorWallet   String              @map("creator_wallet")
  refCode         String              @unique @map("ref_code")
  contentUrl      String?             @map("content_url")
  platform        Platform
  stakeSol        Decimal             @default(0) @map("stake_sol") @db.Decimal(18, 9)
  status          DraftStatus         @default(draft)
  createdAt       DateTime            @default(now()) @map("created_at")

  campaign        CampaignMetadata    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clicks          Click[]
  conversions     PendingConversion[]

  @@index([campaignId])
  @@index([creatorWallet])
  @@map("leaves_metadata")
}

model Click {
  id              String       @id @default(cuid())
  leafId          String       @map("leaf_id")
  timestamp       DateTime     @default(now())
  ipHash          String?      @map("ip_hash")
  userAgentHash   String?      @map("user_agent_hash")
  referrer        String?

  leaf            LeafMetadata @relation(fields: [leafId], references: [id], onDelete: Cascade)

  @@index([leafId, timestamp])
  @@map("clicks")
}

model PendingConversion {
  id            String           @id @default(cuid())
  leafId        String           @map("leaf_id")
  valueUsdc     Decimal          @map("value_usdc") @db.Decimal(18, 6)
  sourceData    Json             @map("source_data")
  status        ConversionStatus @default(pending)
  pushedTxSig   String?          @map("pushed_tx_sig")
  createdAt     DateTime         @default(now()) @map("created_at")

  leaf          LeafMetadata     @relation(fields: [leafId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("pending_conversions")
}

model RefCodeReservation {
  refCode     String   @id @map("ref_code")
  campaignId  String   @map("campaign_id")
  reservedBy  String   @map("reserved_by")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("ref_code_reservations")
}

enum PayoutKind {
  node
  leaf
}

model PayoutClaim {
  id                     String     @id @default(cuid())
  campaignId             String     @map("campaign_id")
  campaignOnchainPda     String     @map("campaign_onchain_pda")
  sourceOnchainPda       String     @map("source_onchain_pda")
  kind                   PayoutKind
  creatorWallet          String     @map("creator_wallet")
  amountUsdc             Decimal    @map("amount_usdc") @db.Decimal(18, 6)
  stakeReleasedLamports  BigInt     @default(0) @map("stake_released_lamports")
  txSignature            String     @unique @map("tx_signature")
  slot                   BigInt     @default(0)
  claimedAt              DateTime   @default(now()) @map("claimed_at")

  campaign               CampaignMetadata @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([creatorWallet, claimedAt])
  @@index([campaignId])
  @@map("payout_claims")
}
