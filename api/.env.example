# Copy to .env and fill in real values. NEVER commit .env.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
PORT=3401
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Oracle webhook used to push register_conversion on-chain. POST is sent from
# /demo/convert with the leaf path + value. Leave empty for offline mode (the
# pending_conversion row sits in 'pending' until something else processes it).
ORACLE_WEBHOOK_URL=http://localhost:3001
# Must match WEBHOOK_TOKEN on the oracle side. Required when the oracle is
# configured with WEBHOOK_TOKEN set.
ORACLE_WEBHOOK_TOKEN=
