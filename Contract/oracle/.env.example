PORT=3001
RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=8wsaheyJ3e1e8zRUFX22apjvutNcaEagTyk21N75Ybz8

# --- Keypair del oracle (usar UNA de las dos opciones) ---

# Opción A: ruta al archivo JSON tipo solana-keygen (RECOMENDADO).
# B3 ya generó este archivo en `indexer/oracle.json` con pubkey
# FkSMCtbcPdeNJLSnzMxWn8biR1fPyUF1wqLHhwGNdoEU
ORACLE_KEYPAIR_PATH=../../indexer/oracle.json

# Opción B: secret key en base58. Tener cuidado, NO commitear.
# ORACLE_PRIVATE_KEY=PEGAR_AQUÍ_BASE58

# --- Verificación cruzada con backend de B (recomendado por spec) ---
# El oracle hace GET a esta URL pasando conversion_id, leaf_pubkey y campaign_pubkey
# antes de firmar. Si la respuesta es 200 con { valid: true }, sigue. Si es 4xx o
# { valid: false }, rechaza la conversión. Dejar vacío para modo demo (sin backend).
BACKEND_VERIFY_URL=

# --- Bearer token para autenticar inbound webhooks ---
# Si se define, el oracle rechaza con 401 cualquier POST a /webhook/conversion
# que no traiga `Authorization: Bearer <WEBHOOK_TOKEN>`. El API debe configurar
# el mismo valor en ORACLE_WEBHOOK_TOKEN. Dejar vacío para deshabilitar la
# autenticación (no recomendado en producción).
WEBHOOK_TOKEN=
