# Copy to .env and fill in real values. NEVER commit .env.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# B/mcp server (streamable HTTP transport)
MCP_URL=http://localhost:4000/mcp

# B/api base URL (SSE + REST fallbacks)
B1_API_URL=http://localhost:3001

# Solana
RPC_URL=https://api.devnet.solana.com
# PROGRAM_ID is filled by Group A once the Anchor program is deployed.
PROGRAM_ID=
WALLET_PATH=./agent-wallet.json

# Master switch: set to "true" only after B/mcp ships create_node_build
# and Group A pre-funds the agent wallet.
ENABLE_ONCHAIN=false

LOG_LEVEL=info
