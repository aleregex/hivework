# Hivework — frontend env vars.
# Copy to .env for local dev. In Vercel, set them under Project Settings → Environment Variables.
# .env is gitignored; commit only this file.

# --- Backend ---
# Group B's HTTP api. Defaults to localhost when unset; override for staging/prod deploys.
NEXT_PUBLIC_API_URL=http://localhost:3401

# Short-link domain that surfaces in the publish-flow QR + bio link.
NEXT_PUBLIC_SHORTLINK_DOMAIN=hivework.link

# --- Solana / Anchor ---
# Solana RPC. Defaults to public devnet if unset; switch to a paid RPC (Helius/QuickNode)
# before the demo if devnet gets congested.
NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com

# Hivework program deployed on devnet. IDL lives at web/lib/anchor/idl/hivework.json.
# Group A: 8wsaheyJ3e1e8zRUFX22apjvutNcaEagTyk21N75Ybz8
NEXT_PUBLIC_PROGRAM_ID=8wsaheyJ3e1e8zRUFX22apjvutNcaEagTyk21N75Ybz8

# Oracle pubkey authorized to sign register_conversion. Used as the
# `oracle_authority` account in create_campaign. From COORDINATION.md.
NEXT_PUBLIC_ORACLE_AUTHORITY=FkSMCtbcPdeNJLSnzMxWn8biR1fPyUF1wqLHhwGNdoEU

# USDC mint used as the campaign escrow asset. The hackathon team uses a custom
# devnet mint (`spl-token create-token --decimals 6` per Contract/INTEGRATION.md).
# Set this to the mint pubkey that the brand wallet has tokens for. If unset,
# /campaigns/new blocks the submit with an explicit error.
NEXT_PUBLIC_USDC_MINT=
