# Hivework — frontend env vars
# Copy to .env.local for local dev. In Vercel, set them under Project Settings → Environment Variables.

# Solana RPC. Defaults to devnet if unset; switch to a paid RPC (Helius/QuickNode) before the demo
# if devnet gets congested.
NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com

# Anchor program pubkey on devnet. Group A fills this in once they deploy.
NEXT_PUBLIC_PROGRAM_ID=

# Backend API URL. Group B fills this in once the backend is deployed.
NEXT_PUBLIC_API_URL=

# Short-link domain for leaf referral codes. Group B owns this.
NEXT_PUBLIC_SHORTLINK_DOMAIN=hivework.link
